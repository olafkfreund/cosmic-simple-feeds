[Desktop Entry]
Name=Feeds
Comment=RSS feed reader applet for the COSMIC™ desktop
Type=Application
Icon=io.github-olafkfreund.cosmic-ext-applet-feeds
Exec=feeds %F
Terminal=false
StartupNotify=true
Categories=COSMIC
Keywords=COSMIC
NoDisplay=true
X-CosmicApplet=true
X-CosmicHoverPopup=Auto
MimeType=
